{
  "name": "maptile-proxy",
  "type": "module",
  "version": "1.1.5",
  "packageManager": "pnpm@11.1.2",
  "description": "A map tile proxy server",
  "author": "",
  "license": "ISC",
  "main": "index.ts",
  "scripts": {
    "dev": "tsx --max-old-space-size=3072 --optimize-for-size src/index.ts",
    "start": "tsx --env-file .env.local src/index.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "serve": "node --max-old-space-size=3072 --optimize-for-size dist/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@hono/node-server": "^2.0.2",
    "@smithy/node-http-handler": "^4.7.3",
    "canvas": "^3.2.3",
    "hono": "^4.12.19",
    "hono-pino": "^0.10.3",
    "nodom": "^2.4.0",
    "ol": "^10.9.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/node": "^24.12.4",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^10.4.0",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3"
  }
}
